<section class="page-hero compact-hero">
  <div class="container">
    <p class="eyebrow">Community</p>
    <h1>부동산 커뮤니티</h1>
    <p>
      매매, 전세, 정책, 실거주 지역 정보까지 자유롭게 의견을 나누는
      공간입니다.
    </p>
    <div class="chip-list">
      <% communityHighlights.forEach((item) => { %>
        <span class="chip"><%= item %></span>
      <% }) %>
    </div>
  </div>
</section>

<section class="content-section">
  <div class="container two-column-layout">
    <div>
      <% if (message) { %>
        <div class="alert success" data-auto-dismiss="true"><%= message %></div>
      <% } %>
      <% if (error) { %>
        <div class="alert error"><%= error %></div>
      <% } %>

      <div class="section-heading">
        <div>
          <h2>최신 게시글</h2>
          <p><strong><%= selectedRegionLabel %></strong> 기준으로 동적으로 게시글을 보여줍니다.</p>
        </div>
        <a class="button button-primary" href="/community/write">글쓰기</a>
      </div>

      <div class="ad-slot">
        <span>Community List AdSense Placeholder</span>
        <small>커뮤니티 리스트 상단 광고 영역</small>
      </div>

      <div class="post-list">
        <% if (posts && posts.length > 0) { %>
          <% posts.forEach((post, index) => { %>
            <article class="post-item">
              <div class="post-meta">
                <span class="tag"><%= post.category %></span>
                <span class="tag"><%= post.region || "전국" %></span>
                <span><%= formatDate(post.created_at) %></span>
                <span>댓글 <%= formatNumber(post.comment_count) %></span>
                <span>조회 <%= formatNumber(post.views_count) %></span>
              </div>
              <h3>
                <a href="/community/<%= post.id %>"><%= post.title %></a>
              </h3>
              <p><%= post.excerpt %></p>
              <a class="text-link" href="/community/<%= post.id %>">
                자세히 보기
              </a>
            </article>

            <% if (index === 1) { %>
              <div class="ad-slot inline-ad">
                <span>Inline Feed AdSense Placeholder</span>
                <small>커뮤니티 피드 중간 광고 영역</small>
              </div>
            <% } %>
          <% }) %>
        <% } else { %>
          <article class="post-item">
            <h3>아직 커뮤니티 글이 없습니다.</h3>
            <p>첫 게시글을 남겨 커뮤니티를 시작해 보세요.</p>
          </article>
        <% } %>
      </div>
    </div>

    <aside class="sticky-panel">
      <div class="form-card">
        <h2>글 작성하기</h2>
        <p>새 글을 작성하려면 전용 작성 페이지로 이동하세요.</p>
        <a class="button button-primary button-block" href="/community/write">
          글쓰기 페이지 열기
        </a>
      </div>

      <div class="seo-panel">
        <h2>SEO 운영 팁</h2>
        <ul class="feature-list">
          <li>실거주 후기형 제목 사용</li>
          <li>지역명 + 거래유형 키워드 포함</li>
          <li>댓글 유도로 페이지 갱신 빈도 증가</li>
          <li>커뮤니티 글을 콘텐츠 페이지로 재활용</li>
        </ul>
      </div>
    </aside>
  </div>
</section>
