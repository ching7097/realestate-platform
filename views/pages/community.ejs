<section class="community-plaza content-section">
  <% const safeDisplaySlug = (typeof displayBoardSlug !== "undefined" && displayBoardSlug) ? displayBoardSlug : ((typeof activeBoardSlug !== "undefined" && activeBoardSlug) ? activeBoardSlug : "free"); %>
  <% const safeDisplayLabel = (typeof displayBoardLabel !== "undefined" && displayBoardLabel) ? displayBoardLabel : ((typeof activeBoardLabel !== "undefined" && activeBoardLabel) ? activeBoardLabel : "자유게시판"); %>
  <% const safeSlug = (safeDisplaySlug || "") || "free"; %>
  <div class="container community-plaza-inner">
    <% if (typeof message !== "undefined" && message) { %>
      <div class="community-plaza-alerts">
        <div class="alert success" data-auto-dismiss="true"><%= (message || "") %></div>
      </div>
    <% } %>
    <% if (typeof error !== "undefined" && error) { %>
      <div class="community-plaza-alerts">
        <div class="alert error"><%= (error || "") %></div>
      </div>
    <% } %>

    <aside class="community-plaza-sidebar community-plaza-sidebar--left" aria-label="게시판 카테고리">
      <div class="community-panel">
        <h2 class="community-panel__title">게시판</h2>
        <p class="community-panel__hint">자유 · 질문 · 정보 · 후기</p>
        <nav class="community-board-nav">
          <% (communityBoards || []).forEach((b) => { %>
            <% const bs = (b && b.slug) ? b.slug : "free"; %>
            <% const bl = (b && b.label) ? b.label : "게시판"; %>
            <a
              class="community-board-nav__link <%= (safeSlug || "") === (bs || "") ? "is-active" : "" %>"
              href="/community?board=<%= encodeURIComponent((bs || "") || "free") %>"
            ><%= (bl || "") %></a>
          <% }) %>
        </nav>
      </div>
    </aside>

    <main class="community-plaza-main">
      <header class="community-main-head">
        <div>
          <h1 class="community-main-head__title"><%= (safeDisplayLabel || "") || "자유게시판" %></h1>
          <p class="community-main-head__sub">제목 · 조회수 · 등록일 · HOT/NEW</p>
        </div>
        <a class="button button-primary community-main-head__write" href="/community/write">글쓰기</a>
      </header>

      <div class="community-panel community-panel--flush">
        <div class="community-table-wrap">
          <table class="community-post-table">
            <thead>
              <tr>
                <th class="col-badges" scope="col">상태</th>
                <th scope="col">제목</th>
                <th class="col-date" scope="col">등록일</th>
              </tr>
            </thead>
            <tbody>
              <% const rows = posts || []; %>
              <% if (!rows.length) { %>
                <tr>
                  <td class="community-post-table__empty" colspan="3">등록된 글이 없습니다.</td>
                </tr>
              <% } %>
              <% rows.forEach((post) => { %>
                <% const pid = post && post.id != null ? String(post.id) : ""; %>
                <% const ptitle = post && post.title != null ? String(post.title) : ""; %>
                <% const rawDate = post && post.created_at ? new Date(post.created_at) : null; %>
                <% const dateOk = rawDate && !Number.isNaN(rawDate.getTime()); %>
                <% const dateStr = dateOk ? rawDate.toLocaleDateString("ko-KR", { year: "numeric", month: "2-digit", day: "2-digit" }) : "-"; %>
                <tr
                  class="community-post-row"
                  data-post-row-href="/community/<%= (pid || "") %>"
                  tabindex="0"
                  role="link"
                  aria-label="게시글 상세 보기"
                >
                  <td class="col-badges">
                    <span class="community-badges">
                      <% if (post && post.isHot) { %><span class="badge badge-hot">HOT</span><% } %>
                      <% if (post && post.isNew) { %><span class="badge badge-new">NEW</span><% } %>
                    </span>
                  </td>
                  <td class="community-post-titlecell">
                    <div class="community-post-titlewrap">
                      <a class="community-post-title" href="/community/<%= (pid || "") %>"><%= (ptitle || "") %></a>
                      <span class="community-post-views-inline" title="조회수">조회 <%= (Number(post && post.views != null ? post.views : 0).toLocaleString("ko-KR") || "") %></span>
                    </div>
                  </td>
                  <td class="col-date">
                    <%= (dateStr || "") %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </main>

    <aside class="community-plaza-sidebar community-plaza-sidebar--right" aria-label="인기·최신 글">
      <div class="community-panel community-panel--section">
        <h2 class="community-panel__title">인기글</h2>
        <p class="community-panel__hint">최근 7일 · 조회수 순</p>
        <ol class="community-side-list community-side-list--with-views">
          <% (popularWeek || []).forEach((p, i) => { %>
            <% const sid = p && p.id != null ? String(p.id) : ""; %>
            <% const st = p && p.title != null ? String(p.title) : ""; %>
            <li>
              <span class="community-side-list__rank"><%= String((i + 1) || "") %></span>
              <a class="community-side-list__link" href="/community/<%= (sid || "") %>"><%= (st || "") %></a>
              <span class="community-side-list__views">조회 <%= (Number(p && p.views != null ? p.views : 0).toLocaleString("ko-KR") || "") %></span>
            </li>
          <% }) %>
        </ol>
      </div>

      <div class="community-panel community-panel--section">
        <h2 class="community-panel__title">최신글</h2>
        <ul class="community-side-list community-side-list--plain community-side-list--with-views">
          <% (recentGlobal || []).forEach((p) => { %>
            <% const rid = p && p.id != null ? String(p.id) : ""; %>
            <% const rt = p && p.title != null ? String(p.title) : ""; %>
            <li>
              <a class="community-side-list__link" href="/community/<%= (rid || "") %>"><%= (rt || "") %></a>
              <span class="community-side-list__views">조회 <%= (Number(p && p.views != null ? p.views : 0).toLocaleString("ko-KR") || "") %></span>
            </li>
          <% }) %>
        </ul>
      </div>

      <div class="community-panel community-panel--section ad-slot ad-slot-community-rail" aria-label="조회수 상위">
        <h2 class="community-panel__title">조회 TOP</h2>
        <p class="community-panel__hint">전체 기간 · 조회수 순</p>
        <ol class="community-side-list community-side-list--with-views">
          <% (topViewedAll || []).forEach((p, i) => { %>
            <% const tid = p && p.id != null ? String(p.id) : ""; %>
            <% const tt = p && p.title != null ? String(p.title) : ""; %>
            <li>
              <span class="community-side-list__rank"><%= String((i + 1) || "") %></span>
              <a class="community-side-list__link" href="/community/<%= (tid || "") %>"><%= (tt || "") %></a>
              <span class="community-side-list__views">조회 <%= (Number(p && p.views != null ? p.views : 0).toLocaleString("ko-KR") || "") %></span>
            </li>
          <% }) %>
        </ol>
      </div>
    </aside>
  </div>
</section>
