<section class="content-section">
  <div class="container">
    <h1>글쓰기</h1>
    <% if (error) { %>
      <div class="alert error"><%= error %></div>
    <% } %>
    <form method="POST" action="/community/write" class="stack-form">
      <label>
        게시판
        <select name="board" required>
          <% (communityBoards || []).forEach((b) => { %>
            <option value="<%= b.label %>" <%= formData.board === b.label ? "selected" : "" %>><%= b.label %></option>
          <% }) %>
        </select>
      </label>
      <label>
        제목
        <input type="text" name="title" value="<%= formData.title %>" required />
      </label>
      <label>
        내용
        <textarea name="content" rows="10" required><%= formData.content %></textarea>
      </label>
      <label>
        지역
        <select name="region">
          <% communityRegions.forEach((region) => { %>
            <option value="<%= region %>" <%= formData.region === region ? "selected" : "" %>><%= region %></option>
          <% }) %>
        </select>
      </label>
      <label>
        구·군
        <input type="text" name="district" value="<%= formData.district %>" />
      </label>
      <button class="button button-primary" type="submit">등록</button>
    </form>
    <p><a href="/community">목록</a></p>
  </div>
</section>
