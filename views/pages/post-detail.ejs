<section class="content-section">
  <div class="container">
    <h1><%= post.title %></h1>
    <p>조회 <%= formatNumber(post.views ?? post.views_count ?? 0) %> · <%= formatDate(post.created_at) %></p>
    <div class="article-content">
      <%- String(post.content || "").replace(/\n/g, "<br />") %>
    </div>
    <p><a href="/community">목록으로</a></p>
  </div>
</section>
